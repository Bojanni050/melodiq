{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/tracks/[id]",
      "regex": "^/api/tracks/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/tracks/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/tracks/[id]/download",
      "regex": "^/api/tracks/([^/]+?)/download(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/tracks/(?<nxtPid>[^/]+?)/download(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/api/auth/login",
      "regex": "^/api/auth/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/auth/login(?:/)?$"
    },
    {
      "page": "/api/auth/logout",
      "regex": "^/api/auth/logout(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/auth/logout(?:/)?$"
    },
    {
      "page": "/api/auth/register",
      "regex": "^/api/auth/register(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/auth/register(?:/)?$"
    },
    {
      "page": "/api/credits",
      "regex": "^/api/credits(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/credits(?:/)?$"
    },
    {
      "page": "/api/generate",
      "regex": "^/api/generate(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/generate(?:/)?$"
    },
    {
      "page": "/api/llm",
      "regex": "^/api/llm(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/llm(?:/)?$"
    },
    {
      "page": "/api/logs",
      "regex": "^/api/logs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/logs(?:/)?$"
    },
    {
      "page": "/api/tracks",
      "regex": "^/api/tracks(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/tracks(?:/)?$"
    },
    {
      "page": "/api/webhooks/poyo",
      "regex": "^/api/webhooks/poyo(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/webhooks/poyo(?:/)?$"
    },
    {
      "page": "/api/webhooks/tempolor",
      "regex": "^/api/webhooks/tempolor(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/webhooks/tempolor(?:/)?$"
    },
    {
      "page": "/library",
      "regex": "^/library(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/library(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
