{
  "$schema": "https://app.kilo.ai/config.json",
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "environment": {
        "DEFAULT_MINIMUM_TOKENS": "{{DEFAULT_MINIMUM_TOKENS}}"
      }
    },
    "sequentialthinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "hindsight": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "http://localhost:8888/mcp/Bojan"
      ]
    },
    "stash": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "http://localhost:8080/sse"
      ]
    },
    "microsoft-learn": {
      "type": "remote",
      "url": "https://learn.microsoft.com/api/mcp"
    }
  }
}