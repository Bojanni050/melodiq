# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/musiq?schema=public"

# Auth
JWT_SECRET="change-me-to-a-random-secret"
JWT_EXPIRES_IN="7d"
WEBHOOK_SECRET="change-me-to-a-random-webhook-secret"

# Google Lyria 3
LYRIA_API_KEY=""
LYRIA_MODEL="lyria-3"

# PoYo (Suno)
POYO_API_KEY=""
POYO_WEBHOOK_URL="http://localhost:3000/api/webhooks/poyo"
POYO_WAV_WEBHOOK_URL="http://localhost:3000/api/webhooks/poyo-wav"

# Tempolor
TEMPOLOR_API_KEY=""
TEMPOLOR_WEBHOOK_URL="http://localhost:3000/api/webhooks/tempolor"

# OpenRouter (for AI optimize & lyrics)
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-5"

# OpenAI fallback
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# Pixazo (cover art - Flux 1 Schnell, free)
PIXAZO_API_KEY=""

# S3 Storage
S3_ENDPOINT=""
S3_REGION="auto"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="musiq-tracks"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
